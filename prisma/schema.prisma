generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  login      String   @unique
  password   String
  name       String
  role       String   @default("EDUCATOR") // "ADMIN" or "EDUCATOR"
  gender           String?  // "MALE" or "FEMALE"
  telegramId       String?  @unique
  telegramLinkCode String?  @unique
  createdAt        DateTime @default(now())

  // O'quvchilar bu tarbiyachiga tegishli (Guruh aloqasi)
  students  Student[]
  scoreLogs ScoreLog[]
}

model Student {
  id         String   @id @default(cuid())
  name       String
  studentId  String   @unique // ST001
  gender     String   @default("MALE") // "MALE" or "FEMALE"
  createdAt  DateTime @default(now())

  educatorId String?
  educator   User?    @relation(fields: [educatorId], references: [id])

  studentUser   StudentUser?
  monthlyScores MonthlyScore[]
  scoreLogs     ScoreLog[]
}

model StudentUser {
  id         String  @id @default(cuid())
  login      String  @unique
  password         String
  studentId        String  @unique
  telegramId       String? @unique
  telegramLinkCode String? @unique

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model MonthlyScore {
  id        String @id @default(cuid())
  studentId String
  month     Int    // 1-12
  year      Int
  score     Int    @default(100)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, month, year])
}

model Category {
  id        String  @id @default(cuid())
  name      String
  minPoints Int
  maxPoints Int
  order     Int
  isActive  Boolean @default(true)

  scoreLogs ScoreLog[]
}

model ScoreLog {
  id             String   @id @default(cuid())
  pointsDeducted Int
  comment        String
  isCancelled    Boolean  @default(false)
  cancelledById  String?
  cancelledAt    DateTime?
  cancelReason   String?
  createdAt      DateTime @default(now())

  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  educatorId String
  educator   User     @relation(fields: [educatorId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
}
